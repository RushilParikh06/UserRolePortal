<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Portal</title>
    <meta name="description" content="User Role Management Portal - Admin Dashboard" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/dropdown.css" asp-append-version="true" />

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Source+Code+Pro:wght@547&display=swap" rel="stylesheet">

    <script>
        const savedTheme = localStorage.getItem('theme') || 'dark';
        document.documentElement.setAttribute('data-theme', savedTheme);
    </script>
</head>

<body>
    <div id="wrapper">

        <!-- Left Sidebar (icon-only, expands on hover) -->
        <nav id="sidebar">
            <div class="nav flex-column mt-3">
                <i class="fas fa-bars top-button"></i>
                <a class="nav-link @(ViewData["Title"]?.ToString() =="Dashboard" ?"active" :"")"
                   asp-controller="Dashboard" asp-action="Index">
                   @if(User.IsInRole("Admin") || User.IsInRole("SuperAdmin")) {<i class="fa-solid fa-fw fa-user-gear fa-xl"></i>}
                   else {<i class="fa-solid fa-user fa-xl"></i>}
                    <span class="link-text">Dashboard</span>
                </a>

                @if (User.IsInRole("Admin") || User.IsInRole("SuperAdmin"))
                {
                    <a class="nav-link @(ViewData["Title"]?.ToString() =="User List" ?"active" :"")"
                       asp-controller="Dashboard" asp-action="UserList">
                       <i class="fa-solid fa-fw fa-cubes fa-xl"></i>
                       <span class="link-text">User List</span>
                    </a>
                }


                <a class="nav-link @(ViewData["Title"]?.ToString() =="Documents" ?"active" :"")"
                   asp-controller="Dashboard" asp-action="UploadDocument">
                   <i class="fa-solid fa-file-arrow-up fa-xl"></i>
                    <span class="link-text">Documents</span>
                </a>

                <hr class="sidebar-divider" />
            </div>
        </nav>

        <div id="content-wrapper">

            <!-- Top Bar -->
            <header id="topbar">
                <div class="d-flex align-items-center gap-3">
                    @if(User.IsInRole("SuperAdmin"))
                    {
                        <span class="d-flex align-items-center gap-2" style="color: #ff5b00; font-size: 13px; font-weight: 700;">
                            <i class="fas fa-crown"></i> Super Admin
                        </span>
                        <span style="color: rgba(255,255,255,0.15);">|</span>
                    }
                    else if(User.IsInRole("Admin"))
                    {
                        <span class="d-flex align-items-center gap-2" style="color: #ff5b00; font-size: 13px; font-weight: 700;">
                            <i class="fas fa-shield-alt"></i> Admin
                        </span>
                        <span style="color: rgba(255,255,255,0.15);">|</span>
                    }
                    else
                    {
                        <span class="d-flex align-items-center gap-2" style="color: #ff5b00; font-size: 13px; font-weight: 700;">
                            <i class="fas fa-user"></i> User
                        </span>
                        <span style="color: rgba(255,255,255,0.15);">|</span>
                    }
                    <h4 class="m-0 fw-bold" style="color: var(--text-main);" >@ViewData["Title"]</h4>
                </div>

                <div class="d-flex align-items-center gap-2">
               
                    
                    <button id="themeToggle" class="btn btn-sm px-3" style="background: transparent; color: var(--text-main); border: 1px solid var(--border-color); font-weight: 600;">
                        <i class="fas fa-sun" id="themeIcon"></i>
                    </button>

                    <span class="me-2 fw-semibold" style="font-size: 13px; color: var(--text-main);">

                        <i class="fas fa-user-circle me-1"></i> @(User.FindFirst("FullName")?.Value ??"User")
                    </span>

                    <a asp-controller="Home" asp-action="Index"
                        class="btn btn-sm px-3" style="background: #ff5b00; color: #000; border: none; font-weight: 700;">
                        <i class="fas fa-fw fa-home me-1"></i> Home
                    </a>

                    <a asp-controller="Account" asp-action="Logout"
                       class="btn btn-sm px-3" style="background: transparent; color: var(--text-main); border: 1px solid var(--border-color); font-weight: 600;">
                        <i class="fas fa-sign-out-alt me-1"></i> Logout
                    </a> 
                </div>
            </header>

            <!-- Main Content -->
            <main class="main-content">
                @RenderBody()
            </main>

        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/custom-dropdown.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const toggleBtn = document.getElementById('themeToggle');
            const icon = document.getElementById('themeIcon');
            
            if(!toggleBtn) return;
            
            function updateIcon(theme) {
                if (theme === 'dark') {
                    icon.className = 'fas fa-sun';
                } else {
                    icon.className = 'fas fa-moon';
                }
            }
            
            const currentTheme = document.documentElement.getAttribute('data-theme');
            updateIcon(currentTheme);

            toggleBtn.addEventListener('click', () => {
                let theme = document.documentElement.getAttribute('data-theme');
                let newTheme = theme === 'dark' ? 'light' : 'dark';
                document.documentElement.setAttribute('data-theme', newTheme);
                localStorage.setItem('theme', newTheme);
                updateIcon(newTheme);
            });
        });
    </script>
</body>

</html>