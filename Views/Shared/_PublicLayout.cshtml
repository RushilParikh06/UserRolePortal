<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - User Role Management Portal</title>
    <meta name="description" content="A professional user role management portal for secure registration, login, and administration." />

    <!-- Bootstrap 5.3 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Font Awesome Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <!-- Google Fonts Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <!-- Google Fonts Source Code Pro -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Source+Code+Pro:wght@400;500;600;700&display=swap" rel="stylesheet" />

    <!-- Custom Styles (loaded AFTER Bootstrap to override defaults) -->
    <link rel="stylesheet" href="~/css/custom.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/dropdown.css" asp-append-version="true" />
</head>
<body>
    <!-- Top Navigation Bar -->
    <nav class="app-topbar">
        <div class="app-topbar-inner">
            <a href="/" class="app-logo">
                <span class="logo-star">&#10035;</span>
            </a>
            <div class="topbar-actions">
                @if (User.Identity != null && User.Identity.IsAuthenticated)
                {
                    <span class="logged-user">
                        <i class="fas fa-user-circle me-1"></i> @(User.FindFirst("FullName")?.Value ?? "User")
                    </span>
                    <a asp-controller="Account" asp-action="Logout" class="topbar-btn topbar-btn-logout">Logout</a>
                }
            </div>
        </div>
    </nav>

    <!-- Main Content Area -->
    <main class="app-main">
        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="app-footer">
        <div class="footer-inner">
            <div class="footer-links">
                <a href="#">Terms &amp; Conditions</a>
                <a href="#">Privacy Policy</a>
            </div>
            <div class="footer-contact">
                <p>rushilparikh06&#64;gmail.com</p>
                <p>+91 7567369600</p>
            </div>
        </div>
    </footer>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/lib/jquery/dist/jquery.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
