</div>

<!-- PDF VIEWER MODAL -->
<div class="modal fade" id="pdfViewerModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-fullscreen" style="margin:0;">
        <div class="modal-content border-0" style="background:#0e0c0d;">

            <!-- Header bar -->
            <div class="modal-header border-0 px-4 py-2 d-flex align-items-center"
                 style="background:#141112; border-bottom:1px solid rgba(255,91,0,0.2); min-height:54px;">
                <div class="d-flex align-items-center gap-2 me-auto">
                    <div class="rounded-2 d-flex align-items-center justify-content-center"
                         style="width:32px; height:32px; background:rgba(255,91,0,0.15);">
                        <i class="fas fa-file-pdf" style="color:#ff5b00; font-size:14px;"></i>
                    </div>
                    <span id="pdfViewerTitle" class="fw-semibold text-white" style="font-size:14px; max-width:480px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;"></span>
                </div>

                <!-- Action buttons in header -->
                <div class="d-flex align-items-center gap-2">
                    <a id="pdfDownloadBtn" href="#" download
                       class="act-btn ghost" style="font-size:12px;" title="Download">
                        <i class="fas fa-file-download"></i> Download
                    </a>
                    <button class="act-btn ghost" style="font-size:12px;" title="Print"
                            onclick="printPdf()">
                        <i class="fas fa-print"></i> Print
                    </button>
                    <button type="button" class="act-btn red" style="font-size:12px;" title="Close viewer"
                            data-bs-dismiss="modal">
                        <i class="fas fa-times"></i> Close
                    </button>
                </div>
            </div>

            <!-- PDF iframe — uses browser's built-in PDF viewer -->
            <div class="modal-body p-0" style="height:calc(100vh - 54px); overflow:hidden;">
                <iframe id="pdfViewerFrame"
                        src=""
                        style="width:100%; height:100%; border:none;"
                        title="PDF Viewer">
                    <p class="text-white p-4">Your browser does not support inline PDF viewing.
                        <a id="pdfFallbackLink" href="#" style="color:#ff5b00;">Click here to download the file.</a>
                    </p>
                </iframe>
            </div>

        </div>
    </div>
</div>

@section Scripts {
<script>
    // ── Toast ────────────────────────────────
    function showToast(msg, type) {
        const t = document.getElementById('actionToast');
        const i = document.getElementById('toastIcon');
        const s = document.getElementById('toastMessage');
        const map = {
            success: { color:'#28c76f', cls:'fas fa-check-circle' },
            error:   { color:'#dc3545', cls:'fas fa-times-circle' },
            info:    { color:'#ff5b00', cls:'fas fa-circle-notch fa-spin' }
        };
        const m = map[type] || map.info;
        t.style.borderLeftColor = m.color;
        i.className = m.cls; i.style.color = m.color;
        s.textContent = msg;
        t.style.top = '22px';
        setTimeout(() => t.style.top = '-80px', 3500);
    }

    // ── Delete ───────────────────────────────
    function setDeleteId(id, name) {
        document.getElementById('deleteDocumentId').value = id;
        document.getElementById('deleteDocumentName').textContent = name;
    }
    function confirmDelete() {
        const id = document.getElementById('deleteDocumentId').value;
        bootstrap.Modal.getInstance(document.getElementById('deleteModal')).hide();
        showToast('Deleting document…', 'info');
        fetch('/Dashboard/DeleteDocument/' + id, { method: 'POST' })
        .then(r => r.json())
        .then(d => {
            if (d.success) { showToast('Document deleted successfully.', 'success'); setTimeout(() => location.reload(), 1200); }
            else showToast(d.message || 'Delete failed.', 'error');
        }).catch(() => showToast('Network error.', 'error'));
    }

    // ── Verify ───────────────────────────────
    function setVerifyId(id, name) {
        document.getElementById('verifyDocumentId').value = id;
        document.getElementById('verifyDocumentName').textContent = name;
    }
    function confirmVerify() {
        const id = document.getElementById('verifyDocumentId').value;
        bootstrap.Modal.getInstance(document.getElementById('verifyModal')).hide();
        showToast('Approving document…', 'info');
        fetch('/Dashboard/VerifyDocument/' + id, { method: 'POST' })
        .then(r => r.json())
        .then(d => {
            if (d.success) { showToast('Document approved & verified!', 'success'); setTimeout(() => location.reload(), 1200); }
            else showToast(d.message || 'Verify failed.', 'error');
        }).catch(() => showToast('Network error.', 'error'));
    }

    // ── Reject ───────────────────────────────
    function setRejectId(id, name) {
        document.getElementById('rejectDocumentId').value = id;
        document.getElementById('rejectDocumentName').textContent = name;
        document.getElementById('rejectReason').value = '';
        document.getElementById('rejectReasonError').style.display = 'none';
    }
    function confirmReject() {
        const id     = document.getElementById('rejectDocumentId').value;
        const reason = document.getElementById('rejectReason').value.trim();
        if (!reason) {
            document.getElementById('rejectReasonError').style.display = 'block';
            document.getElementById('rejectReason').focus(); return;
        }
        document.getElementById('rejectReasonError').style.display = 'none';
        bootstrap.Modal.getInstance(document.getElementById('rejectModal')).hide();
        showToast('Submitting rejection…', 'info');
        fetch('/Dashboard/RejectDocument/' + id + '?reason=' + encodeURIComponent(reason), { method: 'POST' })
        .then(r => r.json())
        .then(d => {
            if (d.success) { showToast('Document rejected. User notified.', 'error'); setTimeout(() => location.reload(), 1400); }
            else showToast(d.message || 'Reject failed.', 'error');
        }).catch(() => showToast('Network error.', 'error'));
    }

    // ── Feedback (user) ──────────────────────
    function setFeedback(fileName, reason) {
        document.getElementById('feedbackFileName').textContent = fileName;
        document.getElementById('feedbackReason').textContent   = reason || 'No reason provided.';
    }

    // ── Filter / Search ──────────────────────
    window.currentRoleTypeFilter = 2; // Default to Users
    
    function filterByRoleType(type) {
        window.currentRoleTypeFilter = type;
        if (type === 2) {
            document.getElementById('users-tab').style.color = '#ff5b00';
            document.getElementById('users-tab').style.background = '#1a1617';
            document.getElementById('admins-tab').style.color = 'rgba(255,255,255,0.5)';
            document.getElementById('admins-tab').style.background = 'transparent';
        } else {
            document.getElementById('admins-tab').style.color = '#ff5b00';
            document.getElementById('admins-tab').style.background = '#1a1617';
            document.getElementById('users-tab').style.color = 'rgba(255,255,255,0.5)';
            document.getElementById('users-tab').style.background = 'transparent';
        }
        filterTable();
    }

    function filterTable() {
        const q      = (document.getElementById('searchInput')?.value || '').toLowerCase();
        const filter = document.getElementById('statusFilter')?.value || '';
        const activeRoleTypeFilter = window.currentRoleTypeFilter || 2;
        const isSuperAdmin = document.getElementById('users-tab') !== null;
        
        const rows   = document.querySelectorAll('#documentTable tbody tr');
        let count    = 0;
        rows.forEach(row => {
            if (row.cells.length < 3) return;
            
            let roleTypeMatch = true;
            if (isSuperAdmin) {
                const roleType = parseInt(row.getAttribute('data-roletype') || 2);
                roleTypeMatch = (roleType === activeRoleTypeFilter);
            }

            const match = row.textContent.toLowerCase().includes(q)
                       && (!filter || row.getAttribute('data-status') === filter)
                       && roleTypeMatch;
            row.style.display = match ? '' : 'none';
            if (match) count++;
        });
        const rc = document.getElementById('resultCount');
        if (rc) rc.innerHTML = `<strong style="color:#ff5b00;">${count}</strong> of <strong>@totalDocs</strong> documents`;
    }

    // ── Tooltips + Init ───────────────────────
    document.addEventListener('DOMContentLoaded', () => {
        // Initialize tooltips for standard elements and all action buttons
        document.querySelectorAll('[data-bs-toggle="tooltip"], .act-btn[title]').forEach(el => new bootstrap.Tooltip(el, { trigger: 'hover' }));

        // Clear iframe when viewer modal is closed
        document.getElementById('pdfViewerModal').addEventListener('hidden.bs.modal', () => {
            document.getElementById('pdfViewerFrame').src = '';
        });

        makeColumnsResizable();
        attachSortListeners();
    });

    // ═══════════════════════════════════════════
    // COLUMN RESIZE
    // ═══════════════════════════════════════════
    function makeColumnsResizable() {
        const table    = document.getElementById('documentTable');
        const handles  = table.querySelectorAll('.col-resizer');

        handles.forEach(handle => {
            const th = handle.parentElement;
            let startX, startW;

            handle.addEventListener('mousedown', e => {
                e.preventDefault();
                e.stopPropagation();          // don't trigger sort click
                startX = e.pageX;
                startW = th.offsetWidth;
                handle.classList.add('dragging');
                document.body.style.cursor = 'col-resize';
                document.body.style.userSelect = 'none';

                function onMove(e) {
                    const newW = Math.max(40, startW + (e.pageX - startX));
                    th.style.width = newW + 'px';
                    th.style.minWidth = newW + 'px';
                }
                function onUp() {
                    handle.classList.remove('dragging');
                    document.body.style.cursor = '';
                    document.body.style.userSelect = '';
                    document.removeEventListener('mousemove', onMove);
                    document.removeEventListener('mouseup', onUp);
                }
                document.addEventListener('mousemove', onMove);
                document.addEventListener('mouseup', onUp);
            });
        });
    }

    // ═══════════════════════════════════════════
    // COLUMN SORT
    // ═══════════════════════════════════════════
    let _sortCol = -1;
    let _sortAsc = true;

    // Status sort order: Pending=1, Verified=2, Rejected=3
    const STATUS_ORDER = { 'Pending': 1, 'Verified': 2, 'Rejected': 3 };

    function attachSortListeners() {
        const ths = document.querySelectorAll('#docTableHead th[data-sort]');
        ths.forEach(th => {
            th.addEventListener('click', e => {
                // Ignore clicks on the resize handle itself
                if (e.target.classList.contains('col-resizer')) return;
                const col     = parseInt(th.getAttribute('data-col'));
                const sortType = th.getAttribute('data-sort');
                if (_sortCol === col) {
                    _sortAsc = !_sortAsc;
                } else {
                    _sortCol = col;
                    _sortAsc = true;
                }
                updateSortIcons(th);
                sortTable(col, sortType, _sortAsc);
            });
        });
    }

    function updateSortIcons(activeTh) {
        document.querySelectorAll('#docTableHead th[data-sort]').forEach(th => {
            th.classList.remove('sort-asc', 'sort-desc');
            const icon = th.querySelector('.sort-icon');
            if (icon) { icon.textContent = '⇅'; icon.style.opacity = '.4'; icon.style.color = ''; }
        });
        const icon = activeTh.querySelector('.sort-icon');
        if (_sortAsc) {
            activeTh.classList.add('sort-asc');
            if (icon) { icon.textContent = '↑'; icon.style.opacity = '1'; icon.style.color = '#ff5b00'; }
        } else {
            activeTh.classList.add('sort-desc');
            if (icon) { icon.textContent = '↓'; icon.style.opacity = '1'; icon.style.color = '#ff5b00'; }
        }
    }

    function sortTable(colIndex, sortType, asc) {
        const tbody = document.querySelector('#documentTable tbody');
        const rows  = Array.from(tbody.querySelectorAll('tr')).filter(r => r.cells.length > 2);

        rows.sort((a, b) => {
            const cellA = a.cells[colIndex];
            const cellB = b.cells[colIndex];
            if (!cellA || !cellB) return 0;

            let valA = cellA.innerText.trim();
            let valB = cellB.innerText.trim();

            if (sortType === 'number') {
                return asc ? (parseFloat(valA)||0) - (parseFloat(valB)||0)
                           : (parseFloat(valB)||0) - (parseFloat(valA)||0);
            }
            if (sortType === 'date') {
                const dA = new Date(valA.split('\n')[0]);
                const dB = new Date(valB.split('\n')[0]);
                return asc ? dA - dB : dB - dA;
            }
            if (sortType === 'status') {
                const sA = STATUS_ORDER[valA.trim()] || 99;
                const sB = STATUS_ORDER[valB.trim()] || 99;
                return asc ? sA - sB : sB - sA;
            }
            return asc
                ? valA.toLowerCase().localeCompare(valB.toLowerCase())
                : valB.toLowerCase().localeCompare(valA.toLowerCase());
        });

        // Re-append sorted rows — entire row moves, all data stays together
        rows.forEach(r => tbody.appendChild(r));

        // Re-number the # column
        rows.forEach((r, i) => {
            if (r.cells[0]) r.cells[0].textContent = i + 1;
        });
    }

    // ── PDF Viewer ────────────────────────────
    function openPdfViewer(filePath, fileName) {
        document.getElementById('pdfViewerTitle').textContent = fileName;
        document.getElementById('pdfViewerFrame').src = filePath;
        document.getElementById('pdfDownloadBtn').href = filePath;
        document.getElementById('pdfDownloadBtn').setAttribute('download', fileName);
        if (document.getElementById('pdfFallbackLink')) {
            document.getElementById('pdfFallbackLink').href = filePath;
        }
        new bootstrap.Modal(document.getElementById('pdfViewerModal')).show();
    }

    function printPdf() {
        const frame = document.getElementById('pdfViewerFrame');
        try {
            frame.contentWindow.focus();
            frame.contentWindow.print();
        } catch(e) {
            window.open(frame.src, '_blank');
        }
    }
</script>
}