                </div>
                <button type="button" class="btn-close btn-close-white ms-auto" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body px-4 py-3">
                <p class="mb-2" style="color:rgba(255,255,255,0.5); font-size:12px;">
                    <i class="fas fa-file-pdf me-1" style="color:#ff5b00;"></i>
                    <span id="feedbackFileName" class="fw-semibold text-white"></span>
                </p>
                <div class="rounded-3 p-3" style="background:rgba(255,77,109,0.08); border:1px solid rgba(255,77,109,0.2);">
                    <p class="mb-0" style="color:rgba(255,255,255,0.8); font-size:13px; line-height:1.65;" id="feedbackReason"></p>
                </div>
                <p class="small mt-3 mb-0" style="color:rgba(255,255,255,0.35);">
                    <i class="fas fa-redo me-1" style="color:#ff5b00;"></i>
                    Please fix the issue and re-upload a corrected version.
                </p>
            </div>
            <div class="modal-footer border-0 px-4 pb-4">
                <button type="button" class="act-btn ghost px-4 py-2" data-bs-dismiss="modal" style="border-radius:8px; font-size:13px;">
                    <i class="fas fa-times"></i> Close
