@model List<UserRolePortal.Models.Document>
@{
    ViewData["Title"] = "Upload Document";
}

<div class="container-fluid mt-4 px-4">
    <!-- Upload Form Card -->
    <div class="card shadow-sm mb-5 border-0">
        <div class="card-header bg-dark text-white border-0 py-3">
            <h5 class="mb-0 fw-bold"><i class="fa-solid fa-file-arrow-up me-2"></i> Upload a New Document</h5>
        </div>
        <div class="card-body p-4">
            
            <!-- Success/Error Messages -->
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="fas fa-exclamation-circle me-2"></i>@TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <!-- IMPORTANT: enctype="multipart/form-data" is absolutely required for file uploads! -->
            <form asp-action="UploadDocument" method="post" enctype="multipart/form-data">
                <div class="row align-items-end g-3">
                    <div class="col-md-4">
                        <label class="form-label fw-bold">Aadhar Card <span class="text-danger">*</span></label>
                        <input type="file" name="aadharFile" class="form-control bg-light" required />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-bold">PAN Card <span class="text-danger">*</span></label>
                        <input type="file" name="panFile" class="form-control bg-light" required />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-bold">Other Documents (Optional)</label>
                        <input type="file" name="optionalFiles" class="form-control bg-light" multiple />
                    </div>
                </div>
                <div class="mt-4 text-end">
                    <button type="submit" class="btn text-white fw-bold px-5 py-2" style="background-color: #ff5b00;">
                        <i class="fas fa-upload me-2"></i> Upload Documents
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- search bar & Uploaded Documents Table -->
@if (User.IsInRole("Admin"))
{
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body py-3">
            <div class="row align-items-center">
                <div class="col-md-6">
                    <div class="input-group">
                        <span class="input-group-text border-end-0" style="background: #1a1617; border-color: rgba(255,255,255,0.15); color: rgba(255,255,255,0.5);">
                            <i class="fas fa-search"></i>
                        </span>
                        <input type="text" id="searchInput" class="form-control border-start-0"
                                placeholder="Search documents by file name or uploader..."
                                style="background: #1a1617; color: #fff; border-color: rgba(255,255,255,0.15);"
                                onkeyup="filterTable()">
                    </div>
                </div>
                <div class="col-md-3">
                    <select id="statusFilter" class="form-select custom-select" data-variant="dark" onchange="filterTable()"
                            style="background: #1a1617; color: #fff; border-color: rgba(255,255,255,0.15);">
                        <option value="">All Documents</option>
                        <option value="Verified">Verified</option>
                        <option value="Pending">Pending</option>
                    </select>
                </div>
                <div class="col-md-3 text-end">
                    <span class="small" id="resultCount" style="color: rgba(255,255,255,0.6);">
                        Showing <strong>@(Model?.Count ?? 0)</strong> documents
                    </span>
                </div>
            </div>
        </div>
    </div>
}

    <h5 class="fw-bold mb-3 px-1"></h5>
    <div class="card shadow-sm border-0"> 
        <div class="card-header py-3 d-flex align-items-center justify-content-between" style="background: #1a1617; border-bottom: 1px solid rgba(255,255,255,0.1);">
            <h6 class="m-0 fw-bold text-white">
                <i class="fas fa-regular fa-copy me-2" style="color: #ff5b00;"></i>Recently Uploaded Documents
            </h6>
        </div>
        <div class = "card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0" id="documentTable">
                    <thead>
                        <tr class="text-nowrap" style="background: #1a1617; color: #ffffff; border-bottom: 2px solid #ff5b00;">
                            <th class="py-3 px-4" style="font-size: 15px; font-weight: 1000; letter-spacing: 1px; text-transform: uppercase;">File Name</th>
                            <th class="py-3 px-4" style="font-size: 15px; font-weight: 1000; letter-spacing: 1px; text-transform: uppercase;">Type</th>
                            @if (User.IsInRole("Admin")) {
                                <th class="py-3 px-4" style="font-size: 15px; font-weight: 1000; letter-spacing: 1px; text-transform: uppercase;">Uploaded By</th>
                            }
                            <th class="py-3 px-3" style="font-size: 15px; font-weight: 1000; letter-spacing: 1px; text-transform: uppercase;">Date Uploaded</th>
                            <th class="py-3 px-3" style="font-size: 15px; font-weight: 1000; letter-spacing: 1px; text-transform: uppercase;">Status</th>
                            <th class="text-end py-3 px-4" style="font-size: 15px; font-weight: 1000; letter-spacing: 1px; text-transform: uppercase;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Count > 0)
                        {
                            foreach (var doc in Model)
                            {
                                <tr data-status="@(doc.IsVerified ? "Verified" : "Pending")">
                                    <td class="align-middle fw-semibold px-4 text-white">
                                        <i class="fa-regular fa-file-lines text-light me-2"></i> @doc.FileName
                                    </td>
                                    <td class="align-middle text-white fw-bold" style="color: #ff5b00 !important;">
                                        @doc.DocumentType
                                    </td>
                                    @if (User.IsInRole("Admin")) {
                                        <td class="align-middle text-white">
                                            <i class="fas fa-user-circle text-light me-1"></i> @doc.UploadedBy?.FullName
                                        </td>
                                    }
                                    <td class="align-middle text-white">
                                        @doc.UploadedDate.ToLocalTime().ToString("MMM dd, yyyy - hh:mm tt")
                                    </td>
                                    <td class="align-middle">
                                        @if (doc.IsVerified)
                                        {
                                            <span class="badge bg-success px-3 py-2"><i class="fas fa-check-circle me-1"></i> Verified</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning text-dark px-3 py-2"><i class="fas fa-clock me-1"></i> Pending</span>
                                        }
                                    </td>
                                    <td class="align-middle px-4">
                                        <div class="d-flex justify-content-end align-items-center gap-2">
                                            @if (!doc.IsVerified && User.IsInRole("Admin"))
                                            {
                                                <a class="btn btn-sm btn-outline-success fw-bold" title="Verify Document"
                                                   data-bs-toggle="modal" data-bs-target="#verifyModal"
                                                   onclick="setVerifyId(@doc.DocumentId, '@doc.FileName')">
                                                    <i class="fas fa-check-circle"></i>
                                                </a>
                                            }
                                            <a href="@doc.FilePath" download="@doc.FileName" class="btn btn-sm btn-outline-light fw-bold" title="Download Document">
                                                <i class="fas fa-download"></i>
                                            </a>
                                            @if (!doc.IsVerified || User.IsInRole("Admin"))
                                            {
                                                <a class="btn btn-sm btn-outline-danger fw-bold" title="Delete Document"
                                                    data-bs-toggle="modal" data-bs-target="#deleteModal"
                                                    onclick="setDeleteId(@doc.DocumentId, '@doc.FileName')">
                                                    <i class="fas fa-trash-alt"></i>
                                                </a>
                                            }
                                        </div>
                                    </td>
                                
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center py-5 text-light">
                                    <i class="fas fa-folder-open fa-3x mb-3 opacity-50"></i>
                                    <h5 class="text-white">No documents have been uploaded yet.</h5>
                                    <p class="mb-0 text-white-50">Be the first to upload a document using the form above!</p>
                                </td>
                            </tr>
                        }


                    </tbody>
                </table>
            </div>
        </div>
    </div>

<!-- Delete Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title"><i class="fas fa-exclamation-triangle me-2"></i> Delete Document</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to delete <strong id="deleteDocumentName"></strong>?</p>
                <p class="text-danger small mb-0">This action cannot be undone. The physical file will be permanently deleted from the server.</p>
                <input type="hidden" id="deleteDocumentId" />
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger fw-bold" onclick="confirmDelete()">Delete File</button>
            </div>
        </div>
    </div>
</div>

<!-- Verify Modal -->
<div class="modal fade" id="verifyModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title"><i class="fas fa-check-circle me-2"></i> Verify Document</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to mark <strong id="verifyDocumentName"></strong> as verified?</p>
                <p class="text-muted small mb-0">This will update the document's status to verified.</p>
                <input type="hidden" id="verifyDocumentId" />
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-success fw-bold" onclick="confirmVerify()">Verify Document</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Fills the modal with the correct ID and Filename when the user clicks the trash icon
        function setDeleteId(id, name) {
            document.getElementById('deleteDocumentId').value = id;
            document.getElementById('deleteDocumentName').textContent = name;
        }

        // Sends the AJAX request to the C# controller to delete it
        function confirmDelete() {
            var id = document.getElementById('deleteDocumentId').value;
            
            fetch('/Dashboard/DeleteDocument/' + id, {
                method: 'POST'
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    window.location.reload(); // Refresh the page to make the row disappear
                } else {
                    alert(data.message);
                }
            })
            .catch(error => console.error('Error:', error));
        }

        // Fills the verify modal with the correct ID and Filename
        function setVerifyId(id, name) {
            document.getElementById('verifyDocumentId').value = id;
            document.getElementById('verifyDocumentName').textContent = name;
        }

        // Sends the AJAX request to verify a document
        function confirmVerify() {
            var id = document.getElementById('verifyDocumentId').value;
            
            fetch('/Dashboard/VerifyDocument/' + id, {
                method: 'POST'
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    window.location.reload(); // Refresh to update the status badge
                } else {
                    alert(data.message);
                }
            })
            .catch(error => console.error('Error:', error));
        }

         // Search & Filter functionality for Documents
        function filterTable() {
            var searchText = document.getElementById('searchInput').value.toLowerCase();
            var statusFilter = document.getElementById('statusFilter').value;
            var rows = document.querySelectorAll('#documentTable tbody tr');
            var visibleCount = 0;
            rows.forEach(function(row) {
                // Ignore the "No documents uploaded yet" placeholder row
                if (row.cells.length === 1 && row.cells[0].colSpan === 5) return;
                var text = row.textContent.toLowerCase();
                var status = row.getAttribute('data-status');
                
                var matchesSearch = text.includes(searchText);
                var matchesStatus = !statusFilter || status === statusFilter;
                if (matchesSearch && matchesStatus) {
                    row.style.display = '';
                    visibleCount++;
                } else {
                    row.style.display = 'none';
                }
            });
            document.getElementById('resultCount').innerHTML =
                'Showing <strong>' + visibleCount + '</strong> of <strong>@(Model?.Count ?? 0)</strong> documents';
        }
    </script>
}