@{
    ViewData["Title"] = "Dashboard";
}

<div class="container-fluid mt-4">
    <!-- Welcome Header -->
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <h1 class="h3 mb-1 fw-bold text-white">Welcome back, @ViewBag.FullName!</h1>
            <p class="mb-0" style="color: rgba(255,255,255,0.6);">Here's your dashboard overview</p>
        </div>
        <div class="d-flex align-items-center gap-2">
            <span class="badge fs-6 px-3 py-2" style="background: rgba(255,75,0,0.15); color: #ff4b00; border: 1px solid rgba(255,75,0,0.3);">
                <i class="fas fa-circle me-1" style="font-size: 8px;"></i> @(User.IsInRole("Admin") ? "Admin" : "User")
            </span>
            <span class="badge fs-6 px-3 py-2" style="background: rgba(255,255,255,0.06); color: rgba(255,255,255,0.7); border: 1px solid rgba(255,255,255,0.1);">
                <i class="fas fa-clock me-1" style="font-size: 10px;"></i> @DateTime.Now.ToString("dd MMM yyyy, hh:mm tt")
            </span>
        </div>
    </div>

    <!-- Display error if any -->
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-triangle me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }    

    <!-- Admin-only: Activity Box -->
    @if (User.IsInRole("Admin"))
    {
    <div class="card border-0" style="background: #1a1617;">
        <div class="card-header py-3 d-flex align-items-center justify-content-between" style="background: #1a1617; border-bottom: 1px solid rgba(255,255,255,0.08);">
            <h6 class="mb-0 fw-bold text-white">
                <i class="fas fa-stream me-2" style="color: #ff4b00;"></i>Activity
            </h6>
            <a asp-controller="Dashboard" asp-action="UserList"
               class="text-decoration-none" style="color: #ff4b00; font-size: 13px; font-weight: 600;">
                View All Users <i class="fas fa-arrow-right ms-1" style="font-size: 11px;"></i>
            </a>
        </div>
        <div class="card-body p-0">

            <!-- Session Events -->
            <div class="d-flex align-items-center px-4 py-3" style="border-bottom: 1px solid rgba(255,255,255,0.06);"
                 onmouseenter="this.style.background='rgba(255,75,0,0.04)'" onmouseleave="this.style.background='transparent'">
                <div class="rounded-circle d-flex align-items-center justify-content-center me-3 flex-shrink-0" style="width: 38px; height: 38px; background: rgba(34,197,94,0.12);">
                    <i class="fas fa-sign-in-alt" style="color: #22c55e; font-size: 15px;"></i>
                </div>
                <div class="flex-grow-1">
                    <span class="fw-semibold text-white" style="font-size: 14px;">logged in successfully</span>
                    <br><small style="color: rgba(255,255,255,0.4); font-size: 12px;">@(User.IsInRole("Admin") ? "Administrator" : "User")</small>
                </div>
                <span class="badge rounded-pill px-2 py-1 flex-shrink-0" style="background: rgba(34,197,94,0.15); color: #22c55e; font-size: 11px;">
                    <i class="fas fa-circle me-1" style="font-size: 6px;"></i>Live
                </span>
            </div>

            <!-- Divider with label -->
            <div class="px-4 py-2" style="background: rgba(255,255,255,0.02); border-bottom: 1px solid rgba(255,255,255,0.06);">
                <small style="color: rgba(255,255,255,0.35); font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px;">
                    <i class="fas fa-user-plus me-1"></i> Recent Registrations
                </small>
            </div>

            <!-- Recent User Registrations -->
            @{
                var recentUsers = ViewBag.RecentUsers as List<UserRolePortal.Models.User>;
            }
            @if (recentUsers != null && recentUsers.Any())
            {
                @foreach (var user in recentUsers)
                {
                    var timeAgo = "";
                    if (user.CreatedDate.HasValue)
                    {
                        var diff = DateTime.Now - user.CreatedDate.Value;
                        if (diff.TotalMinutes < 1) timeAgo = "Just now";
                        else if (diff.TotalMinutes < 60) timeAgo = $"{(int)diff.TotalMinutes}m ago";
                        else if (diff.TotalHours < 24) timeAgo = $"{(int)diff.TotalHours}h ago";
                        else if (diff.TotalDays < 7) timeAgo = $"{(int)diff.TotalDays}d ago";
                        else timeAgo = user.CreatedDate.Value.ToString("dd MMM yyyy");
                    }
                    else
                    {
                        timeAgo = "—";
                    }

                    <div class="d-flex align-items-center px-4 py-3" style="border-bottom: 1px solid rgba(255,255,255,0.04); transition: background 0.2s ease;"
                         onmouseenter="this.style.background='rgba(255,75,0,0.04)'" onmouseleave="this.style.background='transparent'">
                        <div class="rounded-circle d-flex align-items-center justify-content-center me-3 flex-shrink-0"
                             style="width: 38px; height: 38px; background: @(user.RoleId == 1 ? "rgba(255,75,0,0.15)" : "rgba(255,255,255,0.06)"); font-size: 14px; font-weight: 700; color: @(user.RoleId == 1 ? "#ff4b00" : "rgba(255,255,255,0.6)");">
                            @user.FullName.Substring(0, 1).ToUpper()
                        </div>
                        <div class="flex-grow-1 min-width-0">
                            <div class="d-flex align-items-center gap-2">
                                <span class="fw-semibold text-white text-truncate" style="font-size: 14px;">@user.FullName</span>
                                <span class="badge rounded-pill px-2 py-1" style="font-size: 10px; background: @(user.RoleId == 1 ? "rgba(255,75,0,0.15)" : "rgba(255,255,255,0.08)"); color: @(user.RoleId == 1 ? "#ff4b00" : "rgba(255,255,255,0.5)");">
                                    @(user.RoleId == 1 ? "Admin" : "User")
                                </span>
                            </div>
                            <small style="color: rgba(255,255,255,0.4); font-size: 12px;">@user.Email</small>
                        </div>
                        <div class="flex-shrink-0 text-end ms-3">
                            <small style="color: rgba(255,255,255,0.3); font-size: 12px;">@timeAgo</small>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="text-center py-4">
                    <i class="fas fa-inbox fa-2x mb-2" style="color: rgba(255,255,255,0.12);"></i>
                    <p style="color: rgba(255,255,255,0.35); font-size: 13px;" class="mb-0">No registrations yet</p>
                </div>
            }
        </div>
    </div>
    }
</div>