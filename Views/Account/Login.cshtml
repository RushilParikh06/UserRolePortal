@using Microsoft.Extensions.Configuration
@{
    ViewData["Title"] = "Login";
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
}

<section class="form-page">
    <div class="form-card">
        <h2>User Login</h2>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <div asp-validation-summary="All"></div>
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <form asp-controller="Account" asp-action="Login" method="post" id="loginForm">
            @Html.AntiForgeryToken()
            <input type="hidden" id="g-recaptcha-response" name="g-recaptcha-response" />

            <div class="form-group">
                <label for="loginUsername">Username <span class="required">*</span></label>
                <input type="text" id="loginUsername" name="Username" required
                       placeholder="Enter your username" autocomplete="username">
            </div>

            <div class="form-group">
                <label for="loginPassword">Password <span class="required">*</span></label>
                <div style="position: relative;">
                    <input type="password" id="loginPassword" name="Password" required
                           placeholder="Enter your password" autocomplete="current-password"
                           style="padding-right: 40px; width: 100%;">
                    <i class="fas fa-eye" id="toggleLoginPassword" 
                       style="position: absolute; right: 15px; top: 50%; transform: translateY(-50%); cursor: pointer; color: #aaa;" 
                       onclick="togglePassword('loginPassword', 'toggleLoginPassword')"></i>
                </div>
            </div>

            <!-- CAPTCHA Section -->
            <div class="form-group captcha-container">
                <label>Security Check <span class="required">*</span></label>

                <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 10px;">
                   
                    <img src="/Account/GetCaptchaImage" id="captchaImage" alt="CAPTCHA Image" style="border: 1px solid #ddd; border-radius: 4px;" />

                    <!-- Refresh icon -->
                    <button type="button" class="btn" title="Get a new image"
                            style="display: flex; align-items: center; justify-content: center; width: 40px; height: 40px; border-radius: 50%; padding: 0;"
                            onclick="document.getElementById('captchaImage').src = '/Account/GetCaptchaImage?' + new Date().getTime();">
                       
                        <i class="fas fa-sync-alt my-custom-icon"></i>
                    </button>
                </div>

                <input type="text" name="CaptchaInput" required
                       placeholder="Type the characters you see above" autocomplete="off" maxlength="5">
            </div>
            <button type="submit" class="submit-btn">Login</button>
        </form>
        <div class="form-footer">
            <a asp-action="Register">Don't have an account? <strong>Register</strong></a>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        function togglePassword(inputId, iconId) {
            const input = document.getElementById(inputId);
            const icon = document.getElementById(iconId);
            
            if (input.type === 'password') {
                input.type = 'text';
                icon.classList.remove('fa-eye');
                icon.classList.add('fa-eye-slash');
            } else {
                input.type = 'password';
                icon.classList.remove('fa-eye-slash');
                icon.classList.add('fa-eye');
            }
        }
    </script>
}